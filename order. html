<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
  import { getFirestore, doc, setDoc, collection } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

  // ربط الإعدادات
  const app = initializeApp(FIREBASE_CONFIG);
  const db = getFirestore(app);

  window.confirmOrder = async function() {
    // 1. التأكد من تسجيل الدخول
    const user = JSON.parse(localStorage.getItem("hs_user"));
    if(!user) {
      alert("يرجى تسجيل الدخول أولاً لإتمام الطلب");
      location.href = "auth.html";
      return;
    }

    // 2. تجميع بيانات الطلب (تأكد أن المتغيرات pkgActive و methodActive موجودة في app.js)
    if(!window.pkgActive) { alert("اختار الباقة أولاً"); return; }

    const btn = document.querySelector(".mo-btn");
    btn.disabled = true;
    btn.innerText = "جاري إرسال الطلب...";

    const orderId = "ord_" + Date.now();
    const orderData = {
      id: orderId,
      uid: user.uid,
      phone: user.phone,
      gameId: user.gameId,
      gameName: user.gameName,
      package: window.pkgActive, // الباقة المختارة
      method: window.methodActive || "غير محدد",
      status: "pending", // حالة الطلب الافتراضية
      createdAt: Date.now(),
      messages: [
        { from: "system", text: "تم استلام طلبك بنجاح، جاري المراجعة.", ts: Date.now() }
      ]
    };

    try {
      // 3. حفظ الطلب في Firestore
      await setDoc(doc(db, "orders", orderId), orderData);
      
      alert("تم إرسال طلبك بنجاح!");
      location.href = "order.html"; // التوجه لصفحة "طلباتي" لمتابعة الطلب
    } catch (e) {
      console.error("Error sending order:", e);
      alert("حدث خطأ أثناء إرسال الطلب، تأكد من اتصال الإنترنت وقواعد البيانات.");
      btn.disabled = false;
      btn.innerText = "تأكيد الطلب";
    }
  };
</script>

